export default function handler(req, res) {
  if (req.method !== "POST") {
    return res.status(405).json({ error: "Method not allowed" });
  }

  const { message } = req.body;

  res.status(200).json({
    explanation: "This message asks you to click a link because a delivery supposedly failed.",
    riskLevel: "medium"
  });
}
